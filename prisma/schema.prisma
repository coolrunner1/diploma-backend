generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model GlobalRole {
  id          Int     @id @default(autoincrement())
  title       String  @db.VarChar(255)
  description String?
  users       User[]

  @@map("GlobalRoles")
}

model ProjectRole {
  id                Int                 @id @default(autoincrement())
  uuid              String              @db.VarChar(255)
  title             String              @db.VarChar(255)
  description       String?
  userRoleInProject UserRoleInProject[]
  taskRoleUsers     TaskRoleUser[]

  @@map("ProjectRoles")
}

model Status {
  id            Int             @id @default(autoincrement())
  uuid          String          @db.VarChar(255)
  title         String          @db.VarChar(255)
  description   String?
  position      Int
  bgColor       String          @map("bg_color") @db.VarChar(255)
  final         Boolean
  projectStatus ProjectStatus[]
  tasks         Task[]

  @@map("Statuses")
}

model User {
  id                Int                 @id @default(autoincrement())
  uuid              String              @db.VarChar(255)
  login             String              @db.VarChar(255)
  password          String              @db.VarChar(255)
  name              String              @db.VarChar(255)
  surname           String              @db.VarChar(255)
  bgColor           String              @map("bg_color") @db.VarChar(255)
  email             String              @db.VarChar(255)
  globalRoleId      Int                 @map("global_role_id")
  createdAt         DateTime            @map("created_at")
  globalRole        GlobalRole          @relation(fields: [globalRoleId], references: [id])
  ownedCompanies    Company[]           @relation("CompanyOwner")
  userCompanies     UserCompany[]
  projectUsers      ProjectUser[]
  tasks             Task[]
  userRoleInProject UserRoleInProject[]
  comments          Comment[]
  taskRoleUser      TaskRoleUser[]

  @@map("Users")
}

model Company {
  id          Int           @id @default(autoincrement())
  uuid        String        @db.VarChar(255)
  name        String        @db.VarChar(255)
  description String?
  phoneNumber String?       @map("phone_number") @db.VarChar(255)
  email       String?       @db.VarChar(255)
  ownerId     Int           @map("owner_id")
  owner       User          @relation("CompanyOwner", fields: [ownerId], references: [id])
  projects    Project[]
  userCompany UserCompany[]

  @@map("Companies")
}

model Project {
  id                Int                 @id @default(autoincrement())
  uuid              String              @db.VarChar(255)
  title             String              @db.VarChar(255)
  description       String?
  editableStatuses  Boolean             @map("editable_statuses")
  companyId         Int                 @map("company_id")
  startDate         DateTime?           @map("start_date") @db.Date
  endDate           DateTime?           @map("end_date") @db.Date
  company           Company             @relation(fields: [companyId], references: [id])
  projectStatus     ProjectStatus[]
  projectUsers      ProjectUser[]
  tasks             Task[]
  userRoleInProject UserRoleInProject[]

  @@map("Projects")
}

model UserCompany {
  id        Int     @id @default(autoincrement())
  userId    Int     @map("user_id")
  companyId Int     @map("company_id")
  user      User    @relation(fields: [userId], references: [id])
  company   Company @relation(fields: [companyId], references: [id])

  @@map("UserCompany")
}

model ProjectStatus {
  projectId Int     @map("project_id")
  statusId  Int     @map("status_id")
  project   Project @relation(fields: [projectId], references: [id])
  status    Status  @relation(fields: [statusId], references: [id])

  @@id([projectId, statusId])
  @@map("ProjectStatus")
}

model ProjectUser {
  id        Int     @id @default(autoincrement())
  projectId Int     @map("project_id")
  userId    Int     @map("user_id")
  project   Project @relation(fields: [projectId], references: [id])
  user      User    @relation(fields: [userId], references: [id])

  @@map("ProjectUser")
}

enum task_type {
  task
  bug
  story
  epic
}

enum task_priority {
  low
  medium
  high
  critical
}

model Task {
  id             Int            @id @default(autoincrement())
  uuid           String         @db.VarChar(255)
  title          String         @db.VarChar(255)
  description    String
  commentSummary String         @map("commentSummary") @db.VarChar(255)
  userId         Int            @map("user_id")
  statusId       Int            @map("status_id")
  messageCount   Int            @map("message_count")
  projectId      Int            @map("project_id")
  position       Int
  type           task_type
  priority       task_priority
  tags           Json
  blockedBy      Int            @map("blocked_by")
  startTimestamp DateTime       @map("start_timestamp")
  endTimestamp   DateTime       @map("end_timestamp")
  project        Project        @relation(fields: [projectId], references: [id])
  user           User           @relation(fields: [userId], references: [id])
  status         Status         @relation(fields: [statusId], references: [id])
  comments       Comment[]
  taskRoleUser   TaskRoleUser[]

  @@map("Tasks")
}

model UserRoleInProject {
  id        Int         @id @default(autoincrement())
  userId    Int         @map("user_id")
  roleId    Int         @map("role_id")
  projectId Int         @map("project_id")
  user      User        @relation(fields: [userId], references: [id])
  role      ProjectRole @relation(fields: [roleId], references: [id])
  project   Project     @relation(fields: [projectId], references: [id])

  @@map("UserRoleInProject")
}

model Comment {
  id     Int    @id @default(autoincrement())
  userId Int    @map("user_id")
  taskId Int    @map("task_id")
  text   String
  task   Task   @relation(fields: [taskId], references: [id])
  user   User   @relation(fields: [userId], references: [id])

  @@map("Comments")
}

model TaskRoleUser {
  userId Int         @map("user_id")
  taskId Int         @map("task_id")
  roleId Int         @map("role_id")
  user   User        @relation(fields: [userId], references: [id])
  task   Task        @relation(fields: [taskId], references: [id])
  role   ProjectRole @relation(fields: [roleId], references: [id])

  @@id([userId, taskId, roleId])
  @@map("TaskRoleUser")
}
