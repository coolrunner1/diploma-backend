DATABASE_URL="postgresql://postgres:postgres@localhost:5432/task_api?schema=public"
PORT=3000
CORS_ORIGIN="http://localhost:3000"

# --- AI (all optional; disabled by default) ---
# Master switch. When false, AI endpoints still work for assignee load checks but skip GigaChat calls.
AI_ENABLED=false

# Override master for individual features (true/false). Leave unset to follow AI_ENABLED.
# AI_COMMENT_SUMMARY_ENABLED=true
# AI_TASK_CHECK_ENABLED=true

# GigaChat (https://developers.sber.ru/docs/ru/gigachat/api/overview)
GIGACHAT_CREDENTIALS=
GIGACHAT_SCOPE=GIGACHAT_API_PERS
GIGACHAT_MODEL=GigaChat-2
# GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_TIMEOUT=60
# Set true in dev if MinDigital root certs are not installed (not for production)
GIGACHAT_TLS_INSECURE=false

# Assignee workload thresholds (always applied on check-correctness)
MAX_OPEN_TASKS_PER_USER=8
MAX_OPEN_TASKS_PER_USER_PROJECT=8

# Max characters stored for AI comment summary
AI_COMMENT_SUMMARY_MAX_CHARS=2000

# Deadline reminder job (separate from AI)
# ENABLE_DEADLINE_REMINDERS=false
# DEADLINE_REMINDER_HOURS=24
